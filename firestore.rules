rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Events ────────────────────────────────────────────────────
    match /events/{eventId} {
      allow read:   if request.auth != null && request.auth.uid == resource.data.hostUid;
      allow create: if request.auth != null && request.resource.data.hostUid == request.auth.uid;
      allow update, delete:
                    if request.auth != null && request.auth.uid == resource.data.hostUid;

      // ── Guests ───────────────────────────────────────────────────
      match /guests/{guestId} {
        allow create: if true;   // guests register without login
        allow get:    if true;   // guest can reload their pass by URL

        // Only the event host can list all guests (dashboard)
        allow list:   if request.auth != null &&
                        get(/databases/$(database)/documents/events/$(eventId)).data.hostUid
                          == request.auth.uid;

        // Only the event host can update (check-in via door scanner)
        allow update: if request.auth != null &&
                        get(/databases/$(database)/documents/events/$(eventId)).data.hostUid
                          == request.auth.uid;
      }
    }

    // ── Contact form submissions ───────────────────────────────────
    match /contacts/{docId} {
      allow create: if true;
    }
  }
}
